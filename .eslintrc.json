{
  "root": true,
  "env": {
    "browser": true,
    "jquery": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 6,
    "sourceType": "module"
  },
  "extends": [
    "prettier"
  ],
  "ignorePatterns": [
    "*.min.js",
    "*.html",
    "*.json",
    "build/*",
    "node_modules/*",
    "public/*",
    "resources/*"
  ],
  "rules": {
    "curly": 0,
    "no-invalid-this": 0,
    "no-var": 0,
    "one-var": 0
  }
}
